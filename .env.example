# App
SECRET_KEY=change-me-in-production
APP_PORT=8000

# Redis (required — used as Celery broker, result backend, and pub/sub)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# File storage
UPLOAD_DIR=uploaded_files
LOG_DIR=logs
INVALID_ROWS_DIR=invalid_rows

# ETL defaults
DEFAULT_BATCH_SIZE=10000
MAX_RETRIES=3
RETRY_DELAY_SECONDS=2.0

# Flower monitoring port
FLOWER_PORT=5555

# Local dev databases (only needed if using --profile local-db)
# Start with: docker compose --profile local-db up -d
#
# IMPORTANT — hostname vs container_name:
#   Docker service names are used as hostnames inside the teemo-net network.
#   When connecting from the app/worker containers use:
#     host: "postgres"  (the service name, NOT "tinyteemo-postgres-local")
#     host: "mysql"     (the service name, NOT "tinyteemo-mysql-local")
#   When connecting from your laptop (outside Docker) use host: "localhost"
#   with the mapped port below.
POSTGRES_DB=teemo_dev
POSTGRES_USER=teemo
POSTGRES_PASSWORD=teemo_secret
POSTGRES_PORT=5432

MYSQL_DB=teemo_dev
MYSQL_USER=teemo
MYSQL_PASSWORD=teemo_secret
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_PORT=3306
